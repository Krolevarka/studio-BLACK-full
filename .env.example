# SMTP-настройки для отправки брифов с формы контактов (server/api/contact.post.ts)
# В продакшене значения можно переопределить переменными NUXT_SMTP_HOST, NUXT_SMTP_PASS и т.д.

# Хост и порт SMTP-сервера
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# true — использовать TLS с самого начала (обычно для порта 465)
SMTP_SECURE=false

# Учётная запись отправителя (для Gmail — адрес и 16-значный пароль приложения)
SMTP_USER=
SMTP_PASS=

# Куда доставлять заявки (по умолчанию — на SMTP_USER)
MAIL_TO=
